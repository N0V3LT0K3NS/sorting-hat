# ============================================================================
# sorting-hat — environment configuration
# ----------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values.
# Missing keys DISABLE the dependent feature; they never block the app.
# ============================================================================

# --- LiveKit -----------------------------------------------------------------
# Realtime voice transport + the Agents framework. Required for the interview.
# Get keys: https://cloud.livekit.io  ->  Project Settings -> Keys
# LIVEKIT_URL is the wss:// project URL shown on the same page.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- OpenRouter --------------------------------------------------------------
# Unified LLM gateway — ALL model calls: the interviewer's brain, the
# background classifier, and the offline classify/fill pipeline.
# OpenAI-compatible; the LiveKit OpenAI plugin reaches it via
# base_url=https://openrouter.ai/api/v1.
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# --- Model selection (optional overrides) ------------------------------------
# Per-job model selection follows the approved Decision 0001
# (docs/decisions/0001-model-selection.md). Each job has a sensible approved
# default baked into the code; set a variable here only to OVERRIDE it (e.g.
# a G17 live test, or a deployment swap). Leave blank to use the approved
# default shown in the comment.
#
# Job 1 — live interviewer brain (default: anthropic/claude-haiku-4.5,
#         fallback anthropic/claude-sonnet-4.6; provider routing: latency).
INTERVIEWER_MODEL=
INTERVIEWER_FALLBACK_MODEL=
# Job 2 — background classifier (default: openai/gpt-oss-120b pinned to Groq,
#         fallback google/gemini-3.1-flash-lite).
BG_CLASSIFIER_MODEL=
BG_CLASSIFIER_FALLBACK_MODEL=
# Job 3 — offline classification (default: anthropic/claude-opus-4.7,
#         challenger/fallback z-ai/glm-5.1).
CLASSIFY_MODEL=
CLASSIFY_FALLBACK_MODEL=
# Job 4 — offline slot-filling (default: anthropic/claude-opus-4.7,
#         challenger/fallback z-ai/glm-5.1).
FILL_MODEL=
FILL_FALLBACK_MODEL=
# Job 5 — STT (default: deepgram/flux-general-en).
STT_MODEL=
# Job 6 — TTS (default: inworld/inworld-tts-1.5-max, fallback cartesia/sonic-3).
TTS_MODEL=
TTS_FALLBACK_MODEL=

# --- Direct-vendor STT/TTS (optional) ----------------------------------------
# STT and TTS are covered by LiveKit Inference behind the LIVEKIT key.
# These are only needed to OVERRIDE Inference with direct-vendor accounts.

# Deepgram — speech-to-text (Flux — conversational STT with turn detection).
# Get key: https://console.deepgram.com  ->  API Keys
DEEPGRAM_API_KEY=

# Cartesia — text-to-speech (Sonic-3 — the Job 6 TTS fallback voice).
# Get key: https://play.cartesia.ai  ->  API Keys
CARTESIA_API_KEY=

# --- Delivery (optional) -----------------------------------------------------
# Only needed if portraits are emailed. Leave blank to use QR/local delivery.
# Get key: https://app.sendgrid.com  ->  Settings -> API Keys
SENDGRID_API_KEY=
DELIVERY_FROM_EMAIL=

# --- Runtime -----------------------------------------------------------------
# Where finished session artifacts (transcript, JSON, portrait PNG) are written.
SESSIONS_DIR=./sessions
