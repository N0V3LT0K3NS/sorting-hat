# sorting-hat kiosk — environment configuration
#
# Copy this file to `.env.local` and fill in the values. The kiosk reads
# these at request time to mint a LiveKit access token; the Python agent
# worker joins the same room using the same LiveKit project credentials.
#
# If these are left blank the kiosk still builds and the idle screen still
# renders — pressing "begin" simply shows a calm, non-fatal error.

# The wss:// URL of your LiveKit project (LiveKit Cloud or self-hosted).
LIVEKIT_URL=wss://your-project.livekit.cloud

# API key + secret from the LiveKit project settings. Used server-side only
# (in the token route handler) — never exposed to the browser.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Optional: the agent name to dispatch into the room. Leave blank to rely on
# automatic agent dispatch (the Python worker joins any room it is assigned).
# NEXT_PUBLIC_AGENT_NAME=

# Base URL of the local delivery server (delivery/server.py). The Complete
# screen polls `<this>/status/<session-id>` for portrait-pipeline progress and
# loads the finished portrait + QR image from it.
#
# This is exposed to the browser (NEXT_PUBLIC_ prefix). It must be the kiosk
# machine's LAN address — NOT `localhost` — because the QR code sends a
# *phone* to this server: a phone cannot resolve the kiosk's `localhost`. Find
# the LAN IP with `ipconfig getifaddr en0` (macOS) or `hostname -I` (Linux).
# `localhost` is fine only when testing the kiosk page on the kiosk itself.
NEXT_PUBLIC_DELIVERY_SERVER_URL=http://localhost:8808

# Optional design branch interface. Leave unset/blank to keep the current
# minimal kiosk UI. Set to 1 at build time to enable the Shape Rotator-style
# voice-reactive interface.
NEXT_PUBLIC_SHAPE_ROTATOR_INTERFACE=
